{
	"manifest_version": 3,
	"name": "Desktop Assistant Browser MCP Bridge",
	"version": "1.0.0",
	"description": "Connects Desktop Assistant's Browser Control MCP server to your already-open Chrome/Edge tabs.",
	"permissions": [
		"activeTab",
		"alarms",
		"cookies",
		"debugger",
		"scripting",
		"storage",
		"tabs"
	],
	"host_permissions": [
		"<all_urls>",
		"http://127.0.0.1/*",
		"http://localhost/*"
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"action": {
		"default_title": "Browser MCP Bridge"
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": false
	}
}
