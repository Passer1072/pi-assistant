<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="TaskPaneApp">
  <Id>{{ID}}</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Desktop Assistant</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="Desktop Assistant · Word Live" />
  <Description DefaultValue="Let the assistant edit the active Word document through an Office add-in." />
  <IconUrl DefaultValue="https://localhost:{{PORT}}/assets/icon-32.png" />
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:{{PORT}}/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
